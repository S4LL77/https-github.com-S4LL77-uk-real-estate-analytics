# ==============================================================================
# UK Real Estate Analytics — Environment Configuration
# Copy this file to '.env' and fill in your actual values.
# OVERVIEW:
#   STORAGE: Set to 'local' for easy development without AWS, or 's3' for prod.
#   SNOWFLAKE: Required for Phase 3 (dbt) to connect.
# ==============================================================================

# --- Snowflake Configuration (dbt / Phase 3) ---
# Your unique Snowflake trial account ID (e.g. xy12345.eu-west-2.aws)
SNOWFLAKE_ACCOUNT=your_account_id_here
SNOWFLAKE_USER=your_username_here
SNOWFLAKE_PASSWORD=your_password_here

# Storage mode: "local" (filesystem) or "s3" (AWS S3)
STORAGE_MODE=local

# AWS Configuration (only needed if STORAGE_MODE=s3)
AWS_REGION=eu-west-2
S3_BUCKET_NAME=uk-real-estate-analytics
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Snowflake (Phase 3+)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=DATA_ENGINEER
SNOWFLAKE_WAREHOUSE=INGEST_WH
SNOWFLAKE_DATABASE=UK_REAL_ESTATE
SNOWFLAKE_SCHEMA=RAW

# Ingestion settings
LAND_REGISTRY_YEARS=2024
LOG_LEVEL=INFO

# Slack alerts (Phase 2+)
SLACK_WEBHOOK_URL=
